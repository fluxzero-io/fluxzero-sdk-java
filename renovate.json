{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "baseBranches": ["main"],
  "commitMessagePrefix": "deps:",
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchManagers": ["maven", "maven-wrapper", "dockerfile", "github-actions"],
      "matchUpdateTypes": ["patch", "minor", "digest", "replacement"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "stabilityDays": 2
    },
    {
      "matchManagers": ["maven", "maven-wrapper", "dockerfile", "github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}