{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "schedule:automergeDaily"],
  "prConcurrentLimit": 5,
  "commitMessagePrefix": "deps:",
  "packageRules": [
    {
      "matchManagers": ["dockerfile", "github-actions", "maven", "maven-wrapper"],
      "matchUpdateTypes": ["digest", "patch", "minor"],
      "groupName": "Automerge Updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "stabilityDays": 2
    },
    {
      "matchManagers": ["dockerfile", "github-actions", "maven", "maven-wrapper"],
      "matchUpdateTypes": ["major"],
      "groupName": "Major Updates",
      "automerge": false
    }
  ]
}
